# --- Nuxt (copy to .env and fill values) ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_KEY=sb_publishable_YOUR_ANON_OR_PUBLISHABLE_KEY
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# Use Session pooler URI (Dashboard -> Connect -> Session pooler), especially on IPv4-only networks/Vercel.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:5432/postgres
SUPABASE_JWT_SECRET=YOUR_SUPABASE_JWT_SECRET

# Dev: fixes "self-signed certificate in certificate chain" when Node does not trust the DB TLS chain (proxy / CA store). Do not use in production unless you understand the risk.
DATABASE_SSL_REJECT_UNAUTHORIZED=false