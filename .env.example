# Supabase — Project Settings → API
# URL: Project URL
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Anon / public client key (NOT the service_role secret, NOT the JWT secret)
# Paste the "anon" / "public" key from the API page. This is required on every request as apikey.
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImFhbWJic3R0Z2Z4eGRsdmtpb2tkIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU4MjQxNTMsImV4cCI6MjA5MTQwMDE1M30.UFxYon3Fc4_DupLl0dIOONYRU51j7hdv-CLLTanj9Nk

# Optional alias if you use a different name in hosting dashboards:
# SUPABASE_ANON_KEY=same_as_above

NUXT_PUBLIC_SITE_URL=http://localhost:3000

# Required for /api/graphql. If db.YOUR_REF.supabase.co gives ENOTFOUND or pages spin forever on Windows, use Session pooler (Dashboard → Connect → Session pooler):
# DATABASE_URL=postgresql://postgres.YOUR_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_REF.supabase.co:5432/postgres?sslmode=require

# Legacy JWT secret (HS256). Still set this if your access tokens use HS256. New Supabase signing keys (ES256) are verified via JWKS when SUPABASE_URL is set.
SUPABASE_JWT_SECRET=your_jwt_signing_secret

# If Node/pg errors with "self-signed certificate in certificate chain" (common behind corporate proxy),
# dev-only escape hatch — do not use in production unless you understand the risk:
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Optional: same values with NUXT_ prefix (overrides the above in production / some hosts)
# NUXT_DATABASE_URL=
# NUXT_SUPABASE_JWT_SECRET=
